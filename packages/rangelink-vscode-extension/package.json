{
  "name": "rangelink-vscode-extension",
  "displayName": "RangeLink",
  "version": "2.0.0",
  "description": "Create sharable links to code ranges in your files. Perfect for documentation, AI prompts, and team collaboration.",
  "categories": [
    "Other"
  ],
  "keywords": [
    "reference",
    "link",
    "range",
    "ai",
    "cursor",
    "terminal",
    "navigation",
    "code sharing",
    "collaboration",
    "clipboard",
    "paste"
  ],
  "homepage": "https://github.com/couimet/rangelink/tree/main/packages/rangelink-vscode-extension#readme",
  "bugs": {
    "url": "https://github.com/couimet/rangelink/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/couimet/rangelink",
    "directory": "packages/rangelink-vscode-extension"
  },
  "license": "MIT",
  "publisher": "couimet",
  "main": "./dist/extension.js",
  "scripts": {
    "clean": "rm -rf out dist coverage *.tsbuildinfo *.vsix",
    "clean:all": "pnpm clean && rm -rf node_modules .eslintcache *.log .vscode-test",
    "compile": "pnpm compile:deps && pnpm generate-version:all && node esbuild.config.js",
    "compile:deps": "cd ../barebone-logger && pnpm clean && pnpm compile && cd ../barebone-logger-testing && pnpm clean && pnpm compile && cd ../rangelink-core-ts && pnpm clean && pnpm compile",
    "generate-version": "node scripts/generate-version.js --copy-to out",
    "generate-version:all": "node scripts/generate-version.js --copy-to out,dist",
    "generate:publish-instructions": "./scripts/generate-publishing-instructions.sh",
    "generate:qa-issue": "./scripts/generate-qa-issue.sh",
    "generate:release-testing-instructions": "./scripts/generate-release-testing-instructions.sh",
    "install-local": "./scripts/install-local.sh",
    "install-local:cursor": "./scripts/install-local.sh cursor",
    "install-local:vscode": "./scripts/install-local.sh vscode",
    "package": "rm -rf *.vsix && ../../scripts/sync-assets.sh && rm -f rangelink-vscode-extension-*.vsix && vsce package --no-dependencies",
    "publish:vsix": "./scripts/publish-from-vsix.sh",
    "release:lock": "./scripts/orchestrate-release-lock.sh",
    "release:prepare": "./scripts/finalize-release.sh",
    "release:start": "./scripts/start-release.sh",
    "test": "jest --coverage",
    "test:coverage": "jest --coverage --coverageReporters=text --coverageReporters=text-summary --coverageReporters=html",
    "test:fast": "jest --coverage --testPathIgnorePatterns '<rootDir>/src/__integration-tests__/' '\\.integration\\.test\\.ts$'",
    "test:release": "./scripts/run-integration-tests.sh",
    "test:release:automated": "./scripts/run-integration-tests.sh --automated --exclude-label requires-extensions --exclude-label cursor",
    "test:release:cursor": "./scripts/qa-cursor.sh",
    "test:release:grep": "./scripts/run-integration-tests.sh --grep",
    "test:release:prepare": "pnpm compile && rm -rf out/__integration-tests__ && tsc -p tsconfig.integration.json && node scripts/setup-integration-test-settings.js",
    "test:release:ubuntu": "./scripts/qa-ubuntu-docker.sh run",
    "test:release:with-extensions": "./scripts/run-integration-tests.sh --with-extensions",
    "test:watch": "jest --watch",
    "validate:qa-coverage": "./scripts/validate-qa-coverage.sh",
    "verify:qa-scripts": "./scripts/verify-qa-scripts.sh",
    "vscode:prepublish": "pnpm --filter rangelink-core-ts compile && pnpm compile && pnpm test",
    "watch": "tsc -watch -p ./"
  },
  "contributes": {
    "commands": [
      {
        "command": "rangelink.copyLinkWithRelativePath",
        "title": "Send RangeLink",
        "category": "RangeLink",
        "icon": "$(link)",
        "enablement": "editorHasSelection"
      },
      {
        "command": "rangelink.copyLinkWithAbsolutePath",
        "title": "Send RangeLink (Absolute)",
        "category": "RangeLink",
        "icon": "$(link-external)",
        "enablement": "editorHasSelection"
      },
      {
        "command": "rangelink.copyPortableLinkWithRelativePath",
        "title": "Send Portable Link",
        "category": "RangeLink",
        "icon": "$(link-external)",
        "enablement": "editorHasSelection"
      },
      {
        "command": "rangelink.copyPortableLinkWithAbsolutePath",
        "title": "Send Portable Link (Absolute)",
        "category": "RangeLink",
        "icon": "$(link-external)",
        "enablement": "editorHasSelection"
      },
      {
        "command": "rangelink.copyLinkOnlyWithRelativePath",
        "title": "Copy RangeLink",
        "category": "RangeLink",
        "icon": "$(clippy)",
        "enablement": "editorHasSelection"
      },
      {
        "command": "rangelink.copyLinkOnlyWithAbsolutePath",
        "title": "Copy RangeLink (Absolute)",
        "category": "RangeLink",
        "icon": "$(clippy)",
        "enablement": "editorHasSelection"
      },
      {
        "command": "rangelink.pasteSelectedTextToDestination",
        "title": "Send Selected Text",
        "category": "RangeLink",
        "icon": "$(symbol-snippet)",
        "enablement": "editorHasSelection"
      },
      {
        "command": "rangelink.showVersion",
        "title": "Show Version Info",
        "category": "RangeLink",
        "icon": "$(info)"
      },
      {
        "command": "rangelink.bindToDestination",
        "title": "Bind to Destination",
        "category": "RangeLink",
        "icon": "$(link)"
      },
      {
        "command": "rangelink.bindToTerminal",
        "title": "Bind to Terminal",
        "category": "RangeLink",
        "icon": "$(link)"
      },
      {
        "command": "rangelink.bindToTerminalHere",
        "title": "Bind Here",
        "category": "RangeLink",
        "icon": "$(link)"
      },
      {
        "command": "rangelink.bindToTextEditor",
        "title": "Bind to Text Editor",
        "category": "RangeLink",
        "icon": "$(link)"
      },
      {
        "command": "rangelink.bindToTextEditorHere",
        "title": "Bind Here",
        "category": "RangeLink",
        "icon": "$(link)"
      },
      {
        "command": "rangelink.bindToCursorAI",
        "title": "Bind to Cursor AI",
        "category": "RangeLink",
        "icon": "$(link)"
      },
      {
        "command": "rangelink.bindToClaudeCode",
        "title": "Bind to Claude Code",
        "category": "RangeLink",
        "icon": "$(link)"
      },
      {
        "command": "rangelink.bindToCustomAiById",
        "title": "Bind to Custom AI by ID",
        "category": "RangeLink",
        "icon": "$(link)"
      },
      {
        "command": "rangelink.bindToGeminiCodeAssist",
        "title": "Bind to Gemini Code Assist",
        "category": "RangeLink",
        "icon": "$(link)"
      },
      {
        "command": "rangelink.bindToGitHubCopilotChat",
        "title": "Bind to GitHub Copilot Chat",
        "category": "RangeLink",
        "icon": "$(link)"
      },
      {
        "command": "rangelink.unbindDestination",
        "title": "Unbind",
        "category": "RangeLink",
        "icon": "$(close)",
        "enablement": "rangelink.isBound"
      },
      {
        "command": "rangelink.jumpToBoundDestination",
        "title": "Jump to Bound Destination",
        "category": "RangeLink",
        "icon": "$(target)"
      },
      {
        "command": "rangelink.openStatusBarMenu",
        "title": "Open Menu",
        "category": "RangeLink",
        "icon": "$(link)"
      },
      {
        "command": "rangelink.bookmark.add",
        "title": "Save Selection as Bookmark",
        "category": "RangeLink",
        "icon": "$(bookmark)",
        "enablement": "editorHasSelection"
      },
      {
        "command": "rangelink.bookmark.list",
        "title": "List Bookmarks",
        "category": "RangeLink",
        "icon": "$(bookmark)"
      },
      {
        "command": "rangelink.pasteFileAbsolutePath",
        "title": "Send File Path (Absolute)",
        "category": "RangeLink",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "rangelink.pasteFileRelativePath",
        "title": "Send File Path",
        "category": "RangeLink",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "rangelink.pasteCurrentFileAbsolutePath",
        "title": "Send Current File Path (Absolute)",
        "category": "RangeLink",
        "icon": "$(file-symlink-file)",
        "enablement": "editorIsOpen"
      },
      {
        "command": "rangelink.pasteCurrentFileRelativePath",
        "title": "Send Current File Path",
        "category": "RangeLink",
        "icon": "$(file-symlink-file)",
        "enablement": "editorIsOpen"
      },
      {
        "command": "rangelink.explorer.bind",
        "title": "RangeLink: Bind Here",
        "icon": "$(link)"
      },
      {
        "command": "rangelink.explorer.pasteFilePath",
        "title": "RangeLink: Send File Path",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "rangelink.explorer.pasteRelativeFilePath",
        "title": "RangeLink: Send Relative File Path",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "rangelink.explorer.unbind",
        "title": "RangeLink: Unbind",
        "icon": "$(close)"
      },
      {
        "command": "rangelink.editorTab.pasteFilePath",
        "title": "RangeLink: Send File Path",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "rangelink.editorTab.pasteRelativeFilePath",
        "title": "RangeLink: Send Relative File Path",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "rangelink.editorContent.pasteFilePath",
        "title": "RangeLink: Send This File's Path",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "rangelink.editorContent.pasteRelativeFilePath",
        "title": "RangeLink: Send This File's Relative Path",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "rangelink.editorContent.bind",
        "title": "RangeLink: Bind Here",
        "icon": "$(link)"
      },
      {
        "command": "rangelink.editorContent.unbind",
        "title": "RangeLink: Unbind",
        "icon": "$(close)"
      },
      {
        "command": "rangelink.editorContext.copyLink",
        "title": "RangeLink: Send RangeLink",
        "icon": "$(link)"
      },
      {
        "command": "rangelink.editorContext.copyLinkAbsolute",
        "title": "RangeLink: Send RangeLink (Absolute)",
        "icon": "$(link)"
      },
      {
        "command": "rangelink.editorContext.copyPortableLink",
        "title": "RangeLink: Send Portable Link",
        "icon": "$(link)"
      },
      {
        "command": "rangelink.editorContext.copyPortableLinkAbsolute",
        "title": "RangeLink: Send Portable Link (Absolute)",
        "icon": "$(link)"
      },
      {
        "command": "rangelink.editorContext.pasteSelectedText",
        "title": "RangeLink: Send Selected Text",
        "icon": "$(clippy)"
      },
      {
        "command": "rangelink.editorContext.saveBookmark",
        "title": "RangeLink: Save Selection as Bookmark",
        "icon": "$(bookmark)"
      },
      {
        "command": "rangelink.terminal.bind",
        "title": "RangeLink: Bind Here",
        "icon": "$(link)"
      },
      {
        "command": "rangelink.terminal.copyLinkGuard",
        "title": "RangeLink: Copy Link (Terminal)",
        "icon": "$(error)"
      },
      {
        "command": "rangelink.terminal.linkBridge",
        "title": "RangeLink: Copy Link to Destination (Terminal)",
        "icon": "$(link)"
      },
      {
        "command": "rangelink.terminal.pasteSelectedTextToDestination",
        "title": "RangeLink: Send Selected Text",
        "icon": "$(symbol-snippet)"
      },
      {
        "command": "rangelink.terminal.unbind",
        "title": "RangeLink: Unbind",
        "icon": "$(close)"
      },
      {
        "command": "rangelink.goToRangeLink",
        "title": "Go to Link",
        "category": "RangeLink",
        "icon": "$(go-to-file)"
      }
    ],
    "configuration": {
      "title": "RangeLink",
      "properties": {
        "rangelink.customAiAssistants": {
          "type": "array",
          "default": [],
          "description": "Custom AI assistants for RangeLink destination picker. At least one command tier required per entry. Run \"Developer: Reload Window\" after changes. See README for details.",
          "title": "Custom AI Assistants",
          "markdownDescription": "Custom AI assistants for the RangeLink destination picker. At least one command tier required per entry. Run **Developer: Reload Window** after changes. See the README for configuration guide and examples.",
          "items": {
            "type": "object",
            "required": [
              "extensionId",
              "extensionName"
            ],
            "properties": {
              "extensionId": {
                "type": "string",
                "description": "VS Code extension identifier (publisher.name) used to detect availability"
              },
              "extensionName": {
                "type": "string",
                "description": "Display name shown in the destination picker menu"
              },
              "insertCommands": {
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "type": "string",
                      "description": "Command ID — link text is passed as the first argument"
                    },
                    {
                      "type": "object",
                      "required": [
                        "command"
                      ],
                      "properties": {
                        "command": {
                          "type": "string",
                          "description": "VS Code command ID"
                        },
                        "args": {
                          "description": "Argument template — use ${content} as placeholder for the link text"
                        }
                      },
                      "additionalProperties": false
                    }
                  ]
                },
                "description": "Tier 1: Commands that accept text directly as an argument (clipboard is never touched). Plain strings pass text as the first argument. Objects use ${content} interpolation in the args template."
              },
              "focusAndPasteCommands": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Tier 2: Commands that focus the AI chat input where VS Code paste commands work. RangeLink auto-pastes via clipboard (clipboard content is preserved)."
              },
              "focusCommands": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Tier 3: Commands that focus/reveal the AI panel but cannot receive paste commands (e.g., webview-based assistants). RangeLink copies the link to clipboard and shows a \"paste now\" toast. Clipboard content is NOT restored."
              }
            },
            "additionalProperties": false
          }
        },
        "rangelink.clipboard.preserve": {
          "type": "string",
          "enum": [
            "always",
            "never"
          ],
          "default": "always",
          "enumDescriptions": [
            "Save and restore clipboard around operations that use it as transport — your prior clipboard content is preserved (default)",
            "Never restore clipboard — clipboard always contains last RangeLink output"
          ],
          "description": "Controls whether RangeLink restores your clipboard after operations that use it as a transport mechanism",
          "title": "Clipboard Preservation"
        },
        "rangelink.smartPadding.pasteLink": {
          "type": "string",
          "enum": [
            "both",
            "before",
            "after",
            "none"
          ],
          "default": "both",
          "enumDescriptions": [
            "Add space before and after (prevents concatenation)",
            "Add space before only",
            "Add space after only",
            "No padding (paste link as-is)"
          ],
          "description": "Smart padding for generated RangeLinks when pasting to destinations",
          "title": "Paste: Link Padding"
        },
        "rangelink.smartPadding.pasteContent": {
          "type": "string",
          "enum": [
            "both",
            "before",
            "after",
            "none"
          ],
          "default": "none",
          "enumDescriptions": [
            "Add space before and after",
            "Add space before only",
            "Add space after only",
            "No padding (paste text exactly as selected)"
          ],
          "description": "Smart padding for selected text when using Paste Selected Text to Destination (R-V)",
          "title": "Paste: Content Padding"
        },
        "rangelink.smartPadding.pasteFilePath": {
          "type": "string",
          "enum": [
            "both",
            "before",
            "after",
            "none"
          ],
          "default": "both",
          "enumDescriptions": [
            "Add space before and after (prevents concatenation)",
            "Add space before only",
            "Add space after only",
            "No padding (paste path as-is)"
          ],
          "description": "Smart padding for file paths when using Paste Path commands",
          "title": "Paste: File Path Padding"
        },
        "rangelink.smartPadding.pasteBookmark": {
          "type": "string",
          "enum": [
            "both",
            "before",
            "after",
            "none"
          ],
          "default": "both",
          "enumDescriptions": [
            "Add space before and after (prevents concatenation)",
            "Add space before only",
            "Add space after only",
            "No padding (paste bookmark as-is)"
          ],
          "description": "Smart padding for saved bookmarks when pasting to destinations",
          "title": "Paste: Bookmark Padding"
        },
        "rangelink.warnOnDirtyBuffer": {
          "type": "boolean",
          "default": true,
          "description": "Show warning when generating link from file with unsaved changes",
          "title": "Warn on Unsaved Changes"
        },
        "rangelink.navigation.showNavigatedToast": {
          "type": "boolean",
          "default": true,
          "description": "Show info toast after successful navigation (e.g., 'Navigated to recipes/baking/chickenpie.ts @ 3:14-314:16')",
          "title": "Navigation: Show Confirmation Toast"
        },
        "rangelink.navigation.showClampingWarning": {
          "type": "boolean",
          "default": true,
          "description": "Show warning toast when navigation position is clamped to file boundaries",
          "title": "Navigation: Show Clamping Warning"
        },
        "rangelink.terminalPicker.maxInline": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "description": "Maximum terminals shown inline in destination picker (extras collapsed into 'More terminals...')",
          "title": "Terminal Picker: Max Inline Items"
        },
        "rangelink.delimiterHash": {
          "type": "string",
          "default": "#",
          "description": "Delimiter used before the range specification (e.g., # in path#L10-L20)",
          "title": "Delimiter: Hash",
          "pattern": "^[^0-9]+$"
        },
        "rangelink.delimiterLine": {
          "type": "string",
          "default": "L",
          "description": "Delimiter used before line numbers (e.g., L in #L10-L20)",
          "title": "Delimiter: Line",
          "pattern": "^[^0-9]+$"
        },
        "rangelink.delimiterPosition": {
          "type": "string",
          "default": "C",
          "description": "Delimiter used before position numbers (e.g., C in #L10C5-L20C10)",
          "title": "Delimiter: Position",
          "pattern": "^[^0-9]+$"
        },
        "rangelink.delimiterRange": {
          "type": "string",
          "default": "-",
          "description": "Delimiter used between start and end positions (e.g., - in #L10-L20)",
          "title": "Delimiter: Range",
          "pattern": "^[^0-9]+$"
        },
        "rangelink.destinations.claudeCode.coldStartDelayMs": {
          "type": "number",
          "default": 1500,
          "minimum": 500,
          "maximum": 15000,
          "description": "Total duration (ms) of the cold-start re-focus window for Claude Code. During this window, focus commands are re-sent at the coldRefocusIntervalMs cadence to ensure the chat panel is ready before paste dispatch.",
          "title": "Claude Code Cold Start Delay"
        },
        "rangelink.destinations.claudeCode.coldRefocusIntervalMs": {
          "type": "number",
          "default": 300,
          "minimum": 100,
          "maximum": 5000,
          "description": "Interval (ms) between successive focus-command re-sends during the Claude Code cold-start window.",
          "title": "Claude Code Cold Re-focus Interval"
        },
        "rangelink.destinations.gemini.coldStartDelayMs": {
          "type": "number",
          "default": 2500,
          "minimum": 500,
          "maximum": 15000,
          "description": "Total duration (ms) RangeLink waits for the Gemini panel to become ready on first use, sending periodic refocus signals. Increase on slower machines if automatic paste does not work. Must be greater than coldRefocusIntervalMs.",
          "title": "Gemini Code Assist Cold Start Delay"
        },
        "rangelink.destinations.gemini.coldRefocusIntervalMs": {
          "type": "number",
          "default": 300,
          "minimum": 100,
          "maximum": 5000,
          "description": "Interval (ms) at which RangeLink re-sends the Gemini focus signal during the cold-start period. Must be less than coldStartDelayMs.",
          "title": "Gemini Code Assist Cold Re-focus Interval"
        },
        "rangelink.features.bookmarks.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Bookmarks feature (beta). Save code locations for quick access later.",
          "title": "Feature: Bookmarks"
        }
      }
    },
    "keybindings": [
      {
        "command": "rangelink.copyLinkWithRelativePath",
        "key": "ctrl+r ctrl+l",
        "mac": "cmd+r cmd+l",
        "when": "editorHasSelection"
      },
      {
        "command": "rangelink.copyLinkWithAbsolutePath",
        "key": "ctrl+r ctrl+shift+l",
        "mac": "cmd+r cmd+shift+l",
        "when": "editorHasSelection"
      },
      {
        "command": "rangelink.copyPortableLinkWithRelativePath",
        "key": "ctrl+r ctrl+p",
        "mac": "cmd+r cmd+p",
        "when": "editorHasSelection"
      },
      {
        "command": "rangelink.copyPortableLinkWithAbsolutePath",
        "key": "ctrl+r ctrl+shift+p",
        "mac": "cmd+r cmd+shift+p",
        "when": "editorHasSelection"
      },
      {
        "command": "rangelink.copyLinkOnlyWithRelativePath",
        "key": "ctrl+r ctrl+c",
        "mac": "cmd+r cmd+c",
        "when": "editorHasSelection"
      },
      {
        "command": "rangelink.copyLinkOnlyWithAbsolutePath",
        "key": "ctrl+r ctrl+shift+c",
        "mac": "cmd+r cmd+shift+c",
        "when": "editorHasSelection"
      },
      {
        "command": "rangelink.pasteSelectedTextToDestination",
        "key": "ctrl+r ctrl+v",
        "mac": "cmd+r cmd+v",
        "when": "editorHasSelection"
      },
      {
        "command": "rangelink.pasteCurrentFileRelativePath",
        "key": "ctrl+r ctrl+f",
        "mac": "cmd+r cmd+f",
        "when": "editorIsOpen"
      },
      {
        "command": "rangelink.pasteCurrentFileAbsolutePath",
        "key": "ctrl+r ctrl+shift+f",
        "mac": "cmd+r cmd+shift+f",
        "when": "editorIsOpen"
      },
      {
        "command": "rangelink.jumpToBoundDestination",
        "key": "ctrl+r ctrl+j",
        "mac": "cmd+r cmd+j"
      },
      {
        "command": "rangelink.bindToDestination",
        "key": "ctrl+r ctrl+d",
        "mac": "cmd+r cmd+d"
      },
      {
        "command": "rangelink.bookmark.add",
        "key": "ctrl+r ctrl+b ctrl+s",
        "mac": "cmd+r cmd+b cmd+s",
        "when": "config.rangelink.features.bookmarks.enabled && editorHasSelection"
      },
      {
        "command": "rangelink.bookmark.list",
        "key": "ctrl+r ctrl+b ctrl+l",
        "mac": "cmd+r cmd+b cmd+l",
        "when": "config.rangelink.features.bookmarks.enabled"
      },
      {
        "command": "rangelink.goToRangeLink",
        "key": "ctrl+r ctrl+g",
        "mac": "cmd+r cmd+g"
      },
      {
        "command": "rangelink.openStatusBarMenu",
        "key": "ctrl+r ctrl+m",
        "mac": "cmd+r cmd+m"
      },
      {
        "command": "rangelink.unbindDestination",
        "key": "ctrl+r ctrl+u",
        "mac": "cmd+r cmd+u",
        "when": "rangelink.isBound"
      },
      {
        "command": "rangelink.terminal.copyLinkGuard",
        "key": "ctrl+r ctrl+c",
        "mac": "cmd+r cmd+c",
        "when": "terminalFocus && terminalTextSelected"
      },
      {
        "command": "rangelink.terminal.linkBridge",
        "key": "ctrl+r ctrl+l",
        "mac": "cmd+r cmd+l",
        "when": "terminalFocus && terminalTextSelected"
      },
      {
        "command": "rangelink.terminal.pasteSelectedTextToDestination",
        "key": "ctrl+r ctrl+v",
        "mac": "cmd+r cmd+v",
        "when": "terminalFocus && terminalTextSelected"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "rangelink.bindToTerminalHere",
          "when": "false"
        },
        {
          "command": "rangelink.bindToTextEditorHere",
          "when": "false"
        },
        {
