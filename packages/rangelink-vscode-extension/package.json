      "editor/context": [
        {
          "when": "editorHasSelection && (resourceScheme == file || resourceScheme == untitled)",
          "command": "rangelink.editorContext.copyLink",
          "group": "8_rangelink@0"
        },
        {
          "when": "editorHasSelection && (resourceScheme == file || resourceScheme == untitled)",
          "command": "rangelink.editorContext.copyLinkAbsolute",
