out
node_modules
.vscode-test/
*.vsix
.DS_Store
.history
coverage/

# Package manager files (keep pnpm lock in repo for consistency)
package-lock.json
yarn.lock

# Monorepo workspace
packages/*/node_modules/
packages/*/out/
packages/*/dist/
*.tsbuildinfo

# pnpm store (should use global cache)
.pnpm-store/

# Python virtual environment (auto-created by QA scripts for PyYAML)
.venv/

# Generated version files
packages/*/src/version.json

# Build-time assets (copied from /assets/ during package builds)
packages/*/icon.png
packages/*/icon_large.png

# Claude config
.claude/settings.local.json

# Temp files created by integration test suites (cleaned up on normal exit; guard for CI kills)
packages/rangelink-vscode-extension/__rl-test-*.ts

# Generated QA artifacts (not committed)
packages/rangelink-vscode-extension/qa/qa-coverage-report-*.txt
packages/rangelink-vscode-extension/qa/qa-issues-local-*.md
packages/rangelink-vscode-extension/qa/test-run-*.txt

# Folders where Claude Code is told to create and manage working documents
.breadcrumbs/
.claude-questions/
.commit-msgs/
.scratchpads/
# Claude skill working directories
.claude-work/
